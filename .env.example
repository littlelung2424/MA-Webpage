# Intake submissions are saved to Supabase by app/api/intake/route.ts.
# Configure these in Vercel Project Settings > Environment Variables for each environment you use.

# Required. Use your Supabase project URL, for example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Required. Server-only key used by the API route to insert intake rows.
# Keep this secret. Do not expose it to browser/client code or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Defaults to intake_submissions.
SUPABASE_INTAKE_TABLE=intake_submissions

# Optional on Vercel when the Blob store is connected to the same project.
# For local development, run `vercel env pull` or paste the read-write token here.
BLOB_READ_WRITE_TOKEN=
