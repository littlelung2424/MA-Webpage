# Required for /api/intake to send intake notification emails through Resend.
# Create this in Resend, then add the same value in Vercel Project Settings > Environment Variables.
RESEND_API_KEY=re_your_resend_api_key_here

# Required destination for intake notifications.
# This is the address that receives new intake submissions.
INTAKE_NOTIFY_EMAIL=you@example.com

# Optional verified sender address for Resend.
# If omitted, the app uses: Mission Atlas Intake <onboarding@resend.dev>
# For production, use a sender on a domain verified in Resend, for example:
# INTAKE_FROM_EMAIL=Mission Atlas Intake <intake@missionatlasxd.com>
INTAKE_FROM_EMAIL=

# Optional. If configured, uploaded files are stored in Vercel Blob and linked in the email.
# If omitted, uploaded files are attached directly to the email up to the app's attachment limit.
BLOB_READ_WRITE_TOKEN=
