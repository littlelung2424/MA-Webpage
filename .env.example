# Configure at least one intake delivery option in Vercel Project Settings > Environment Variables.

# Option A: save intake submissions to Supabase.
# Use your project URL, for example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Server-only key used by the API route to insert into the intake table.
# Keep this secret. Do not expose it to browser/client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional table name. Defaults to intake_submissions.
SUPABASE_INTAKE_TABLE=intake_submissions

# Option B: send intake submissions through Resend email notifications.
RESEND_API_KEY=re_your_resend_api_key_here
INTAKE_NOTIFY_EMAIL=you@example.com

# Optional verified sender address for Resend.
# If omitted, the app uses: Mission Atlas Intake <onboarding@resend.dev>
# For production, use a sender on a domain verified in Resend, for example:
# INTAKE_FROM_EMAIL=Mission Atlas Intake <intake@missionatlasxd.com>
INTAKE_FROM_EMAIL=

# Optional. If configured, uploaded files are stored in Vercel Blob and linked in Supabase/email.
# If omitted, Supabase stores file names only; Resend email delivery attaches files directly up to the app's attachment limit.
BLOB_READ_WRITE_TOKEN=
